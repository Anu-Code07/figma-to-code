{
  "name": "@design2code/cli",
  "version": "0.1.0",
  "description": "CLI for Design2Code AI",
  "type": "module",
  "bin": {
    "design2code": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "clean": "rm -rf dist",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@design2code/compiler-core": "workspace:*",
    "@design2code/design-ast": "workspace:*",
    "@design2code/figma-parser": "workspace:*",
    "@design2code/merge-engine": "workspace:*",
    "@design2code/design-token-engine": "workspace:*",
    "@design2code/generator-flutter": "workspace:*",
    "@design2code/generator-react": "workspace:*",
    "@design2code/generator-nextjs": "workspace:*",
    "@design2code/generator-react-native": "workspace:*",
    "commander": "^12.1.0",
    "chalk": "^5.3.0",
    "ora": "^8.1.1"
  },
  "devDependencies": {
    "typescript": "^5.7.2"
  }
}
