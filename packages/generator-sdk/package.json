{
  "name": "@design2code/generator-sdk",
  "version": "0.1.0",
  "description": "Plugin SDK for Design2Code framework generators",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@design2code/design-ast": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.7.2"
  }
}
