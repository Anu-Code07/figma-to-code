{
  "name": "@design2code/compiler-core",
  "version": "0.1.0",
  "description": "Core compiler orchestration for Design2Code AI",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "clean": "rm -rf dist",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@design2code/design-ast": "workspace:*",
    "@design2code/design-token-engine": "workspace:*",
    "@design2code/component-detector": "workspace:*",
    "@design2code/figma-parser": "workspace:*",
    "@design2code/ai-engine": "workspace:*",
    "@design2code/merge-engine": "workspace:*",
    "@design2code/generator-sdk": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
