{
  "name": "@design2code/mcp-server",
  "version": "0.1.1",
  "description": "MCP server for Claude/Cursor integration with Design2Code AI",
  "type": "module",
  "bin": {
    "design2code-mcp": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "clean": "rm -rf dist",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "@design2code/compiler-core": "workspace:*",
    "@design2code/ai-engine": "workspace:*",
    "@design2code/design-ast": "workspace:*",
    "@design2code/figma-parser": "workspace:*",
    "@design2code/merge-engine": "workspace:*",
    "@design2code/generator-flutter": "workspace:*",
    "@design2code/generator-react": "workspace:*",
    "@design2code/generator-nextjs": "workspace:*",
    "@design2code/generator-react-native": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.6.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "typescript": "^5.7.2"
  },
  "license": "MIT",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "bugs": {
    "url": "https://github.com/Anu-Code07/figma-to-code/issues"
  },
  "homepage": "https://github.com/Anu-Code07/figma-to-code#readme",
  "keywords": [
    "figma",
    "design-to-code",
    "codegen",
    "flutter",
    "react",
    "nextjs",
    "mcp"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Anu-Code07/figma-to-code.git",
    "directory": "packages/mcp-server"
  }
}
